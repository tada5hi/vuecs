{
    "name": "@vuecs/theme-tailwind",
    "version": "6.0.0",
    "type": "module",
    "description": "Tailwind CSS theme for vuecs components.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "style": "./assets/index.css",
            "import": "./dist/index.mjs"
        },
        "./index.css": "./assets/index.css",
        "./assets/index.css": "./assets/index.css"
    },
    "style": "./assets/index.css",
    "files": [
        "dist",
        "assets"
    ],
    "keywords": [
        "vuecs",
        "theme",
        "tailwind",
        "tailwindcss"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "themes/tailwind"
    },
    "sideEffects": [
        "./assets/*.css"
    ],
    "scripts": {
        "build:js": "tsdown",
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage"
    },
    "dependencies": {
        "tailwind-merge": "^3.6.0"
    },
    "devDependencies": {
        "@vuecs/button": "^1.0.4",
        "@vuecs/core": "^3.2.0",
        "@vuecs/countdown": "^2.0.4",
        "@vuecs/design": "^1.0.4",
        "@vuecs/elements": "^1.2.3",
        "@vuecs/forms": "^5.2.1",
        "@vuecs/gravatar": "^2.0.5",
        "@vuecs/list": "^1.0.4",
        "@vuecs/navigation": "^4.0.2",
        "@vuecs/overlays": "^1.1.0",
        "@vuecs/pagination": "^2.1.3",
        "@vuecs/placeholder": "^1.0.4",
        "@vuecs/timeago": "^2.1.0",
        "@vueuse/core": "^14.3.0",
        "jsdom": "^29.1.1",
        "vue": "^3.5.35"
    },
    "peerDependencies": {
        "@vuecs/core": "^3.2.0",
        "@vuecs/design": "^1.0.4",
        "@vueuse/core": "^13.0.0 || ^14.0.0",
        "tailwindcss": "^4.3.0",
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
