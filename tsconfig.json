{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "noUncheckedIndexedAccess": false,
        "verbatimModuleSyntax": false
    },
    "include": ["packages/*/src/**/*"]
}
