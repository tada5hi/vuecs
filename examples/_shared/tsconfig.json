{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": false,
        "noEmit": true,
        "allowImportingTsExtensions": false,
        "verbatimModuleSyntax": false,
        "jsx": "preserve"
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue"
    ],
    "exclude": [
        "node_modules"
    ]
}
