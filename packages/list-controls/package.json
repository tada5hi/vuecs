{
    "name": "@vuecs/list-controls",
    "version": "2.0.1",
    "type": "module",
    "description": "A package containing list controls.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "style": "./dist/style.css",
            "import": "./dist/index.mjs"
        },
        "./style.css": "./dist/style.css",
        "./dist/style.css": "./dist/style.css"
    },
    "style": "./dist/style.css",
    "files": [
        "dist"
    ],
    "keywords": [
        "list",
        "list-controls",
        "vue",
        "layout",
        "hyperscript",
        "components",
        "builder",
        "template"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/list-controls"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types",
        "test": "vitest --config test/vitest.config.ts --run"
    },
    "devDependencies": {
        "@vue/test-utils": "^2.4.8",
        "@vuecs/core": "^2.0.0",
        "jsdom": "^29.0.2",
        "smob": "^1.6.1",
        "vue": "^3.5.33"
    },
    "peerDependencies": {
        "@vuecs/core": "^2.0.0",
        "smob": "^1.6.1",
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
