{
    "name": "@vuecs/link",
    "version": "1.0.1",
    "type": "module",
    "description": "A package containing a link component.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "link",
        "vue-router",
        "nuxt",
        "router-link",
        "nuxt-link",
        "vue"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/link"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types"
    },
    "devDependencies": {
        "vue": "^3.5.33"
    },
    "peerDependencies": {
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
