{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "lib": [
            "ESNext",
            "DOM"
        ],
        "jsx": "preserve",
        "skipLibCheck": true,
        "paths": {
            "@vuecs/core": [
                "./packages/core/src"
            ],
            "@vuecs/core/*": [
                "./packages/core/src/*"
            ],
            "@vuecs/icon": [
                "./packages/icon/src"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ]
}
