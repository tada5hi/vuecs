{
    "name": "@vuecs/navigation",
    "version": "4.1.1",
    "type": "module",
    "description": "A package for multi level navigations.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "style": "./dist/style.css",
            "import": "./dist/index.mjs"
        },
        "./style.css": "./dist/style.css",
        "./dist/style.css": "./dist/style.css"
    },
    "style": "./dist/style.css",
    "files": [
        "dist"
    ],
    "keywords": [
        "navigation",
        "navigation-elements",
        "vue",
        "layout",
        "components",
        "navigation",
        "navbar",
        "tier",
        "multi-tier",
        "level",
        "vue-router"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/navigation"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage"
    },
    "dependencies": {
        "reka-ui": "^2.10.1"
    },
    "devDependencies": {
        "@vue/test-utils": "^2.4.11",
        "@vuecs/core": "^3.3.0",
        "@vuecs/link": "^2.0.2",
        "jsdom": "^29.1.1",
        "vue": "^3.5.39",
        "vue-router": "^5.1.0"
    },
    "peerDependencies": {
        "@vuecs/core": "^3.3.0",
        "@vuecs/link": "^2.0.2",
        "vue": "^3.x",
        "vue-router": "^4.x || ^5.x"
    },
    "peerDependenciesMeta": {
        "vue-router": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
