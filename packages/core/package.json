{
    "name": "@vuecs/core",
    "version": "2.0.0",
    "type": "module",
    "description": "",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [],
