{
    "name": "@vuecs/list",
    "version": "1.0.6",
    "type": "module",
    "description": "Compound list components for vuecs (List / Header / Body / Item / ItemText / ItemActions / Footer / Loading / Empty) plus the defineList() factory + useList() injector. Successor to @vuecs/list-controls — clean break, compound API.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "vue",
        "vuecs",
        "list",
        "components"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/list"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types",
        "test": "npm run build:types && vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage"
    },
    "dependencies": {
        "smob": "^1.6.2"
    },
    "devDependencies": {
        "@vue/test-utils": "^2.4.11",
        "@vuecs/core": "^3.2.2",
        "jsdom": "^29.1.1",
        "vue": "^3.5.38"
    },
    "peerDependencies": {
        "@vuecs/core": "^3.2.2",
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
