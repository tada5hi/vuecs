{
    "name": "@vuecs/form-controls",
    "version": "2.5.0",
    "type": "module",
    "description": "A package containing form controls.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs"
        },
        "./core": {
            "types": "./core/index.d.ts",
            "import": "./core/index.mjs"
        },
        "./dist/style.css": "./dist/style.css"
    },
    "files": [
        "core",
        "dist"
    ],
    "keywords": [
        "vue",
        "layout",
        "hyperscript",
        "components",
        "forms",
        "form-control",
        "builder",
        "template"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/form-controls"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json || true",
        "build": "rimraf dist && npm run build:js && npm run build:types"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1"
    },
    "devDependencies": {
        "@vuecs/core": "^2.0.0",
        "vue": "^3.5.28"
    },
    "peerDependencies": {
        "@vuecs/core": "^2.0.0",
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
