{
    "name": "@vuecs/forms",
    "version": "3.0.0",
    "type": "module",
    "description": "Form controls (inputs, checkbox, switch, select, textarea, range slider) on Reka UI primitives.",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.ts",
            "style": "./dist/style.css",
            "import": "./dist/index.mjs"
        },
        "./style.css": "./dist/style.css",
        "./dist/style.css": "./dist/style.css"
    },
    "style": "./dist/style.css",
    "files": [
        "dist"
    ],
    "keywords": [
        "vue",
        "layout",
        "hyperscript",
        "components",
        "forms",
        "form-control",
        "builder",
        "template"
    ],
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://tada5hi.net"
    },
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/vuecs.git",
        "directory": "packages/forms"
    },
    "scripts": {
        "build:js": "tsdown",
        "build:types": "vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json",
        "build": "rimraf dist && npm run build:js && npm run build:types",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "reka-ui": "^2.9.6"
    },
    "devDependencies": {
        "@vue/test-utils": "^2.4.9",
        "@vuecs/core": "^2.0.0",
        "jsdom": "^29.1.0",
        "vue": "^3.5.33"
    },
    "peerDependencies": {
        "@vuecs/core": "^2.0.0",
        "vue": "^3.x"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
